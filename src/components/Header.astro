---
const navItems = [
  {
    title: "Projects",
    label: "projects",
    url: "/#projects",
  },
  {
    title: "Education",
    label: "education",
    url: "/#education",
  },
  {
    title: "Experience",
    label: "experience",
    url: "/#experience",
  }
]
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-4"
>
  <nav
    class="header-nav flex gap-x-1 px-4 py-1.5 text-sm font-medium rounded-full text-gray-300 justify-center items-center border border-transparent"
  >
    {
      navItems.map((link) => (
        <a
          class="nav-link relative block px-3 py-1.5 rounded-full transition-colors duration-200 hover:text-blue-400"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a")

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            console.log(entry.target.id, entry.isIntersecting)
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("bg-blue-400/10", "text-blue-400")
              item.classList.remove("text-gray-300")
            } else {
              item.classList.remove("bg-blue-400/10", "text-blue-400")
              item.classList.add("text-gray-300")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>
