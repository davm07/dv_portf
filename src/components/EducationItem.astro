---
import MapPin from "./icons/MapPin.astro";
const {education} = Astro.props;
---

<div class="flex group flex-col gap-2">
    <h3 class="text-xl font-bold text-violet-400">{education.title}</h3>
    <div class="flex flex-row w-full gap-x-4 text-white/80">
        <p>
            {education.school}
        </p>
        <p>
            {education.endDate}
        </p>
    </div>
    <p class="flex items-center gap-x-2 text-sm text-white/80">
        <MapPin class="size-4"/>
        {education.location}
    </p>
    <p>{education.description}</p>
</div>