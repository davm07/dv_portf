---
const {experience} = Astro.props;
---
<span class="absolute flex items-center justify-center w-6 h-6 bg-violet-900 rounded-full -inset-s-3 ring-8 ring-gray-950">
    <svg class="size-4 text-violet-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"/></svg>
</span>
<div class="bg-gray-800 border border-gray-600 text-xs  px-1.5 py-0.5 rounded w-fit">
    <time class="font-medium" datetime={experience.startDate.value}>{experience.startDate.label}</time>
    -
    <time class="font-medium" datetime={experience.endDate.value}>{experience.endDate.label}</time>
</div>
<h3 class="flex items-center mb-1 text-xl font-semibold text-violet-400 my-2">{experience.jobTitle}</h3>
<p class="mb-4 text-pretty">{experience.description}</p>